{
  "name": "humanwork-protocol",
  "version": "1.0.0",
  "description": "Decentralized B2B freelancing platform with AI-powered skill verification",
  "private": true,
  "workspaces": ["backend", "frontend"],
  "scripts": {
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:contracts": "cd contracts && forge build",
    "test:contracts": "cd contracts && forge test -vvv"
  },
  "devDependencies": { "concurrently": "^8.2.2" },
  "engines": { "node": ">=18.0.0" },
  "license": "MIT"
}
