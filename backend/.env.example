# ===========================================
# HumanWork Protocol Backend - Environment Variables
# ===========================================

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Hedera Testnet
HEDERA_RPC_URL=https://testnet.hashio.io/api
HEDERA_CHAIN_ID=296

# Oracle Wallet (Backend wallet for AI fulfillment)
ORACLE_PRIVATE_KEY=your_oracle_private_key_here
ORACLE_ADDRESS=0x_your_oracle_address_here

# ===========================================
# Contract Addresses (Update after deployment)
# ===========================================
USDC_ADDRESS=
USER_REGISTRY_ADDRESS=
AGENCY_REGISTRY_ADDRESS=
AI_ORACLE_ADDRESS=
SKILL_TRIAL_ADDRESS=
PROJECT_ESCROW_ADDRESS=
DISPUTE_JURY_ADDRESS=
ENTERPRISE_ACCESS_ADDRESS=
GAS_SPONSOR_ADDRESS=
INSURANCE_POOL_ADDRESS=

# ===========================================
# MongoDB
# ===========================================
MONGODB_URI=

# ===========================================
# IPFS/Filecoin Storage
# ===========================================

# Option 1: Web3.Storage
WEB3_STORAGE_TOKEN=your_web3_storage_token_here

# Option 2: Pinata
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# ===========================================
# Hugging Face AI
# ===========================================
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# ===========================================
# Security
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Encryption Key for ALE (Application Level Encryption)
# Must be exactly 32 characters for AES-256
ENCRYPTION_KEY=12345678901234567890123456789012

# ===========================================
# Event Listener
# ===========================================
POLLING_INTERVAL=3000
START_BLOCK=0
