import { useRef, useMemo } from 'react';
import { Canvas, useFrame, useThree } from '@react-three/fiber';
import { Sparkles } from '@react-three/drei';
import { EffectComposer, Bloom } from '@react-three/postprocessing';
import * as THREE from 'three';

/* ═══════════════════════════════════════════════════════════════════════════
   HeroScene — Clean aurora gradient waves with floating particle constellation.
   Inspired by modern SaaS landing pages — elegant, not cluttered.
   ═══════════════════════════════════════════════════════════════════════════ */

/* Flowing aurora gradient plane */
function AuroraPlane() {
  const meshRef = useRef<THREE.Mesh>(null!) as any;
  const matRef = useRef<THREE.ShaderMaterial>(null!) as any;

  const uniforms = useMemo(() => ({
    uTime: { value: 0 },
    uColorA: { value: new THREE.Color('#e8a317') },
    uColorB: { value: new THREE.Color('#0abdc6') },
    uColorC: { value: new THREE.Color('#080b12') },
  }), []);

  useFrame(({ clock }) => {
    matRef.current.uniforms.uTime.value = clock.getElapsedTime() * 0.15;
  });

  return (
    <mesh ref={meshRef} position={[0, 0, -3]} rotation={[0, 0, 0]}>
      <planeGeometry args={[20, 12, 64, 64]} />
      <shaderMaterial
        ref={matRef}
        uniforms={uniforms}
        transparent
        depthWrite={false}
        vertexShader={`
          varying vec2 vUv;
          varying float vElevation;
          uniform float uTime;
          
          void main() {
            vUv = uv;
            vec3 pos = position;
            float elevation = sin(pos.x * 0.8 + uTime * 2.0) * 0.3 
                            + sin(pos.y * 0.6 + uTime * 1.5) * 0.2
                            + sin((pos.x + pos.y) * 0.4 + uTime) * 0.15;
            pos.z += elevation;
            vElevation = elevation;
            gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
          }
        `}
        fragmentShader={`
          varying vec2 vUv;
          varying float vElevation;
          uniform vec3 uColorA;
          uniform vec3 uColorB;
          uniform vec3 uColorC;
          uniform float uTime;
          
          void main() {
            float mixStrength = (vElevation + 0.5) * 0.5 + 0.25;
            vec3 color = mix(uColorC, uColorB, smoothstep(0.0, 0.5, mixStrength));
            color = mix(color, uColorA, smoothstep(0.5, 1.0, mixStrength) * 0.4);
            
            // Add subtle noise grain
            float grain = fract(sin(dot(vUv * 100.0 + uTime, vec2(12.9898, 78.233))) * 43758.5453);
            color += grain * 0.015;
            
            // Fade edges
            float edgeFade = smoothstep(0.0, 0.15, vUv.x) * smoothstep(1.0, 0.85, vUv.x)
                           * smoothstep(0.0, 0.2, vUv.y) * smoothstep(1.0, 0.8, vUv.y);
            
            gl_FragColor = vec4(color, 0.35 * edgeFade);
          }
        `}
      />
    </mesh>
  );
}

/* Sparse floating particles — elegant constellation */
function FloatingConstellation() {
  const ref = useRef<THREE.Points>(null!) as any;
  const count = 80;

  const { positions, sizes } = useMemo(() => {
    const pos = new Float32Array(count * 3);
    const siz = new Float32Array(count);
    for (let i = 0; i < count; i++) {
      pos[i * 3] = (Math.random() - 0.5) * 14;
      pos[i * 3 + 1] = (Math.random() - 0.5) * 8;
      pos[i * 3 + 2] = (Math.random() - 0.5) * 6 - 1;
      siz[i] = 0.015 + Math.random() * 0.025;
    }
    return { positions: pos, sizes: siz };
  }, []);

  useFrame(({ clock }) => {
    const t = clock.getElapsedTime();
    ref.current.rotation.y = Math.sin(t * 0.05) * 0.1;
    ref.current.rotation.x = Math.cos(t * 0.03) * 0.05;
  });

  return (
    <points ref={ref}>
      <bufferGeometry>
        <bufferAttribute attach="attributes-position" count={count} array={positions} itemSize={3} />
        <bufferAttribute attach="attributes-size" count={count} array={sizes} itemSize={1} />
      </bufferGeometry>
      <pointsMaterial
        color="#e8a317"
        size={0.04}
        transparent
        opacity={0.5}
        sizeAttenuation
        depthWrite={false}
        blending={THREE.AdditiveBlending}
      />
    </points>
  );
}

/* Subtle accent particles — cooler blue layer */
function AccentParticles() {
  const ref = useRef<THREE.Points>(null!) as any;
  const count = 40;

  const positions = useMemo(() => {
    const pos = new Float32Array(count * 3);
    for (let i = 0; i < count; i++) {
      pos[i * 3] = (Math.random() - 0.5) * 16;
      pos[i * 3 + 1] = (Math.random() - 0.5) * 10;
      pos[i * 3 + 2] = (Math.random() - 0.5) * 4 - 2;
    }
    return pos;
  }, []);

  useFrame(({ clock }) => {
    const t = clock.getElapsedTime();
    ref.current.rotation.y = -Math.sin(t * 0.04) * 0.08;
  });

  return (
    <points ref={ref}>
      <bufferGeometry>
        <bufferAttribute attach="attributes-position" count={count} array={positions} itemSize={3} />
      </bufferGeometry>
      <pointsMaterial
        color="#0abdc6"
        size={0.025}
        transparent
        opacity={0.35}
        sizeAttenuation
        depthWrite={false}
        blending={THREE.AdditiveBlending}
      />
    </points>
  );
}

/* Subtle horizon line */
function HorizonLine() {
  return (
    <mesh position={[0, -2.8, -1]} rotation={[-Math.PI / 2, 0, 0]}>
      <planeGeometry args={[20, 0.003]} />
      <meshBasicMaterial color="#e8a317" transparent opacity={0.15} />
    </mesh>
  );
}

/* Camera subtle parallax */
function CameraRig() {
  useFrame(({ camera, pointer }) => {
    camera.position.x += (pointer.x * 0.4 - camera.position.x) * 0.015;
    camera.position.y += (pointer.y * 0.2 - camera.position.y + 0.3) * 0.015;
    camera.lookAt(0, 0, 0);
  });
  return null;
}

/* Mouse-following light */
function MouseLight() {
  const lightRef = useRef<THREE.PointLight>(null!) as any;
  const { viewport } = useThree();

  useFrame(({ pointer }) => {
    const x = (pointer.x * viewport.width) / 2;
    const y = (pointer.y * viewport.height) / 2;
    lightRef.current.position.x += (x - lightRef.current.position.x) * 0.04;
    lightRef.current.position.y += (y - lightRef.current.position.y) * 0.04;
  });

  return (
    <pointLight
      ref={lightRef}
      position={[0, 0, 4]}
      intensity={0.25}
      color="#e8a317"
      distance={15}
      decay={2}
    />
  );
}

export default function HeroScene() {
  return (
    <Canvas
      camera={{ position: [0, 0.3, 6], fov: 35 }}
      dpr={[1, Math.min(window.devicePixelRatio, 2)]}
      gl={{ antialias: true, alpha: true, powerPreference: 'default', toneMapping: THREE.ACESFilmicToneMapping, toneMappingExposure: 1.0 }}
      style={{ position: 'absolute', inset: 0 }}
    >
      <ambientLight intensity={0.08} />
      <pointLight position={[5, 3, 4]} intensity={0.15} color="#e8a317" distance={20} />
      <pointLight position={[-4, -2, 3]} intensity={0.08} color="#0abdc6" distance={15} />

      <MouseLight />
      <AuroraPlane />
      <FloatingConstellation />
      <AccentParticles />
      <HorizonLine />
      <CameraRig />

      <Sparkles count={15} size={0.8} scale={8} color="#e8a317" opacity={0.15} speed={0.1} />

      <EffectComposer>
        <Bloom
          intensity={0.5}
          luminanceThreshold={0.3}
          luminanceSmoothing={0.95}
          mipmapBlur
        />
      </EffectComposer>
    </Canvas>
  );
}
